# Python
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/

# Environment files
.env
.env.*

# AWS credentials - never commit these
.aws/

# Docker
.docker/

# Terraform infrastructure - contains sensitive output
terraform/infrastructure/.terraform/
terraform/infrastructure/*.tfstate
terraform/infrastructure/*.tfstate.backup
terraform/infrastructure/.terraform.lock.hcl

# Terraform backend - contains sensitive output
terraform/backend/.terraform/
terraform/backend/*.tfstate
terraform/backend/*.tfstate.backup
terraform/backend/.terraform.lock.hcl
# Test cache
.pytest_cache/
.coverage
htmlcov/

# IDE
.vscode/
.idea/
*.swp